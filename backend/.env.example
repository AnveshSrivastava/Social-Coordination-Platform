# Spring Boot Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!

# MongoDB Connection (use Atlas or local instance)
SPRING_MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# JWT Configuration
APP_JWT_SECRET=your-secure-random-key-here-minimum-32-chars
APP_JWT_EXPIRATION_MS=3600000

# Server Port (Render will override this)
PORT=8080
